        "import os\n",
        "import torch\n",
        "from ultralytics import YOLO\n",
        "\n",
        "# Detect device\n",
        "device = 0 if torch.cuda.is_available() else \"cpu\"\n",
        "\n",
        "LOCAL_COMBINED = '/content/local_combined_dataset'\n",
        "PROJECT_DIR = '/content/drive/MyDrive/billiards_training'\n",
        "TRAINING_NAME = 'pocket_detector_refined'\n",
        "\n",
        "# Ensure data.yaml exists and has absolute paths\n",
        "data_yaml_path = os.path.join(LOCAL_COMBINED, 'data.yaml')\n",
        "if not os.path.exists(data_yaml_path):\n",
        "    raise FileNotFoundError(f\"Critical: {data_yaml_path} is missing.\")\n",
        "\n",
        "# Path to the last saved checkpoint to resume\n",
        "checkpoint_path = os.path.join(PROJECT_DIR, TRAINING_NAME, 'weights/last.pt')\n",
        "\n",
        "if os.path.exists(checkpoint_path):\n",
        "    print(f\"Resuming training from checkpoint: {checkpoint_path}\")\n",
        "    model = YOLO(checkpoint_path)\n",
        "    resume_flag = True\n",
        "else:\n",
        "    print(\"Checkpoint not found, looking for previous best weights...\")\n",
        "    latest_weights = os.path.join(PROJECT_DIR, 'pocket_detector_final/weights/best.pt')\n",
        "    model = YOLO(latest_weights if os.path.exists(latest_weights) else 'yolov8n.pt')\n",
        "    resume_flag = False\n",
        "\n",
        "# Start/Resume training\n",
        "results = model.train(\n",
        "    data=data_yaml_path,\n",
        "    epochs=50,\n",
        "    imgsz=640,\n",
        "    batch=16 if device == \"cpu\" else 32,\n",
        "    project=PROJECT_DIR,\n",
        "    name=TRAINING_NAME,\n",
        "    device=device,\n",
        "    save=True,\n",
        "    save_period=5,\n",
        "    resume=resume_flag,\n",
        "    plots=True\n",
        ")\n",
        "\n",
        "# Export to TFLite FP16\n",
        "print(\"Training complete. Exporting model...\")\n",
        "export_path = model.export(format='tflite', imgsz=640, half=True, nms=True)\n",
        "\n",
        "print(f\"Refined model training finished and exported to: {export_path}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
