        "device = 0 if torch.cuda.is_available() else 'cpu'\n",
        "COMBINED_DIR = '/content/local_combined_dataset'\n",
        "PROJECT_DIR = '/content/drive/MyDrive/billiards_training'\n",
        "TRAINING_NAME = 'pocket_detector_final_v1'\n",
        "\n",
        "# Define checkpoint path to resume from\n",
        "checkpoint_path = os.path.join(PROJECT_DIR, TRAINING_NAME, 'weights', 'last.pt')\n",
        "\n",
        "if os.path.exists(checkpoint_path):\n",
        "    print(f\"Resuming training from checkpoint: {checkpoint_path}\")\n",
        "    model = YOLO(checkpoint_path)\n",
        "    resume_flag = True\n",
        "else:\n",
        "    print(\"Checkpoint not found, starting fresh with yolov8n.pt\")\n",
        "    model = YOLO('yolov8n.pt')\n",
        "    resume_flag = False\n",
        "\n",
        "# 1. Final Training Push to 100 Epochs\n",
        "# Adjusted batch to 16 and cache=True to optimize for ~6GB GPU memory\n",
        "results = model.train(\n",
        "    data=os.path.join(COMBINED_DIR, 'data.yaml'),\n",
        "    epochs=100,\n",
        "    imgsz=640,\n",
        "    batch=16,\n",
        "    project=PROJECT_DIR,\n",
        "    name=TRAINING_NAME,\n",
        "    device=device,\n",
        "    save=True,\n",
        "    resume=resume_flag,\n",
        "    plots=True,\n",
        "    amp=True,\n",
        "    cache=True\n",
        ")\n",
        "\n",
        "# 2. Final Evaluation\n",
        "metrics = model.val()\n",
        "print(f\"Final mAP50: {metrics.box.map50:.4f}\")\n",
        "\n",
        "# 3. Final Export to TFLite FP16\n",
        "print(\"Training complete. Exporting model to TFLite FP16...\")\n",
        "export_path = model.export(format='tflite', imgsz=640, half=True, nms=True)\n",
        "\n",
        "# 4. Backup to Drive Exports\n",
